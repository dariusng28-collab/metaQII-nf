// =============================================================================
//  metaQII-nf  —  nextflow.config
// =============================================================================

nextflow.enable.strict = true

// -----------------------------------------------------------------------------
// Pipeline parameters
// -----------------------------------------------------------------------------

params {

    // --- Input / output ------------------------------------------------------
    outdir          = 'results'
    input_mode      = 'manifest'
    manifest        = null
    input_dir       = null
    metadata        = null
    classifier      = null

    // --- Sequencing layout ---------------------------------------------------
    paired_end      = true
    sequence_type   = 'ITS'
    its_region      = 'ITS1'
    its_taxa        = 'F'
    run_fastqc      = true

    // --- DADA2 denoising -----------------------------------------------------
    trim_left_f            = 0
    trim_left_r            = 0
    trunc_len_f            = 0
    trunc_len_r            = 0
    dada2_pooling          = 'independent'
    dada2_n_reads_learn    = 1000000

    // --- Diversity & taxonomy ------------------------------------------------
    build_phylogeny            = null       // null → auto: false for ITS, true for 16S
    sampling_depth             = null
    metadata_column            = null
    taxonomy_start_level       = 2
    alpha_rarefaction_min_depth = 1
    alpha_rarefaction_steps    = 10
    plot_top_n_taxa            = 15

    // --- Execution -----------------------------------------------------------
    threads         = 4
    max_cpus        = 16
    max_memory      = '128.GB'
    max_time        = '24.h'
}

// -----------------------------------------------------------------------------
// Process defaults  (no executor here — set per profile)
// -----------------------------------------------------------------------------

process {
    shell        = ['/bin/bash', '-euo', 'pipefail']
    errorStrategy = { task.exitStatus in [140, 143, 137, 104, 134, 139]
                        ? 'retry'
                        : 'finish' }
    maxRetries   = 2

    withLabel: 'qiime' {
        cpus   = { check_max(params.threads as int,          'cpus')   }
        memory = { check_max(8.GB  * task.attempt,           'memory') }
        time   = { check_max(4.h   * task.attempt,           'time')   }
        conda  = "${projectDir}/envs/qiime2-amplicon-2026.1-metaqii.yml"
    }

    withLabel: 'qiime_heavy' {
        cpus   = { check_max(params.threads as int,          'cpus')   }
        memory = { check_max(32.GB * task.attempt,           'memory') }
        time   = { check_max(12.h  * task.attempt,           'time')   }
        conda  = "${projectDir}/envs/qiime2-amplicon-2026.1-metaqii.yml"
    }
}

// -----------------------------------------------------------------------------
// Profiles
// -----------------------------------------------------------------------------

profiles {

    // --- Local / laptop (default) -------------------------------------------
    standard {
        conda.enabled       = false
        process.executor    = 'local'
        process.cpus        = params.threads
    }

    // --- Local with conda environment solving --------------------------------
    conda {
        conda.enabled       = true
        conda.useMamba      = false         // set true if mamba is available
        process.executor    = 'local'
    }

    // --- SGE / UGE ----------------------------------------------------------
    sge {
        conda.enabled           = true
        process.executor        = 'sge'
        process.penv            = 'smp'
        process.queue           = params.containsKey('sge_queue') ? params.sge_queue : 'all.q'
        process.clusterOptions  = { "-V -cwd -l h_vmem=${task.memory.toGiga()}G" }
    }

    // --- SLURM ---------------------------------------------------------------
    slurm {
        conda.enabled           = true
        process.executor        = 'slurm'
        process.queue           = params.containsKey('slurm_queue') ? params.slurm_queue : 'normal'
        process.clusterOptions  = '--export=ALL'
    }

    // --- LSF -----------------------------------------------------------------
    lsf {
        conda.enabled           = true
        process.executor        = 'lsf'
        process.queue           = params.containsKey('lsf_queue') ? params.lsf_queue : 'normal'
        process.clusterOptions  = { "-R 'rusage[mem=${task.memory.toMega()}]'" }
    }

    // --- PBS / Torque --------------------------------------------------------
    pbs {
        conda.enabled           = true
        process.executor        = 'pbs'
        process.queue           = params.containsKey('pbs_queue') ? params.pbs_queue : 'batch'
        process.clusterOptions  = { "-l mem=${task.memory.toGiga()}gb" }
    }

    // --- Pre-built environment (HPC without internet on compute nodes) --------
    // Use this when conda env is already built.
    // Activate the environment before running and pass -profile prebuilt.
    prebuilt {
        conda.enabled           = false
        process.executor        = 'local'   // combine with sge/slurm via -profile prebuilt,slurm
    }

    // --- Test (minimal smoke test) -------------------------------------------
    test {
        params.input_mode       = 'manifest'
        params.manifest         = "${projectDir}/assets/example_manifest.tsv"
        params.metadata         = "${projectDir}/assets/example_metadata.tsv"
        params.sampling_depth   = 100
        params.metadata_column  = 'state_of_disease'
        params.trunc_len_f      = 250
        params.trunc_len_r      = 220
        params.dada2_n_reads_learn = 10000
        params.run_fastqc       = false
        conda.enabled           = true
        process.executor        = 'local'
    }
}

// -----------------------------------------------------------------------------
// Conda settings
// -----------------------------------------------------------------------------

conda {
    createTimeout   = '60 min'
    cacheDir        = "${HOME}/.conda/nextflow-envs"
}

// -----------------------------------------------------------------------------
// Pipeline reports
// -----------------------------------------------------------------------------

timeline {
    enabled     = true
    file        = "${params.outdir}/pipeline_info/timeline.html"
    overwrite   = true
}
report {
    enabled     = true
    file        = "${params.outdir}/pipeline_info/report.html"
    overwrite   = true
}
trace {
    enabled     = true
    file        = "${params.outdir}/pipeline_info/trace.txt"
    overwrite   = true
    fields      = 'task_id,hash,native_id,name,status,exit,submit,start,complete,duration,realtime,cpus,memory,%cpu,%mem,rss,vmem'
}
dag {
    enabled     = true
    file        = "${params.outdir}/pipeline_info/dag.html"
    overwrite   = true
}

// -----------------------------------------------------------------------------
// Resource ceiling helper — prevents requests exceeding what the host allows
// -----------------------------------------------------------------------------

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj as int, params.max_cpus as int)
        } catch (all) { return obj }
    }
}
